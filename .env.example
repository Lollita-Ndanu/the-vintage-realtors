# ==========================================
#   VINTAGE REALTORS - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your values
# These variables are configured in Vercel Dashboard for production
# ==========================================

# -----------------------------------------
#   SUPABASE CONFIGURATION
# -----------------------------------------
# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (recommended for server-side operations)
# Get from: Supabase Dashboard > Settings > API > service_role
# WARNING: This key has full admin access - NEVER expose client-side
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon Key (fallback if service key not available)
# Get from: Supabase Dashboard > Settings > API > anon public
# This has limited permissions based on RLS policies
SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------
#   RESEND EMAIL SERVICE
# -----------------------------------------
# Resend API Key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# -----------------------------------------
#   CONTACT FORM SETTINGS
# -----------------------------------------
# Email address to receive contact form notifications
CONTACT_EMAIL=contacts@thevintagerealtors.com

# Email address to send contact notifications from (must be verified in Resend)
SENDER_EMAIL=contacts@thevintagerealtors.com

# -----------------------------------------
#   NEWSLETTER SETTINGS
# -----------------------------------------
# Email address to send newsletter emails from (must be verified in Resend)
NEWSLETTER_SENDER_EMAIL=newsletters@thevintagerealtors.com
