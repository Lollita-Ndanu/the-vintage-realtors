{
  "buildCommand": "npm run build && cd admin && npm install && npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/properties.html",
      "destination": "/properties",
      "permanent": true
    },
    {
      "source": "/property.html",
      "destination": "/property",
      "permanent": true
    },
    {
      "source": "/location.html",
      "destination": "/location",
      "permanent": true
    },
    {
      "source": "/collaborators.html",
      "destination": "/collaborators",
      "permanent": true
    },
    {
      "source": "/contact.html",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/legal.html",
      "destination": "/legal",
      "permanent": true
    },
    {
      "source": "/termsandconditions.html",
      "destination": "/termsandconditions",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/properties",
      "destination": "/properties.html"
    },
    {
      "source": "/property",
      "destination": "/property.html"
    },
    {
      "source": "/location",
      "destination": "/location.html"
    },
    {
      "source": "/collaborators",
      "destination": "/collaborators.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/legal",
      "destination": "/legal.html"
    },
    {
      "source": "/termsandconditions",
      "destination": "/termsandconditions.html"
    }
  ]
}
